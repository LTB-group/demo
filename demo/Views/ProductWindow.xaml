<Window x:Class="WpfApp4.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="550" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Артикул (Мировой код):" FontSize="14"/>
            <TextBox x:Name="TbCode" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Название:" FontSize="14"/>
            <TextBox x:Name="TbName" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Цена:" FontSize="14"/>
            <TextBox x:Name="TbPrice" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Скидка (%):" FontSize="14"/>
            <TextBox x:Name="TbDiscount" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Производитель:" FontSize="14"/>
            <ComboBox x:Name="CbManufacturer" DisplayMemberPath="Name" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Категория:" FontSize="14"/>
            <ComboBox x:Name="CbCategory" DisplayMemberPath="Name" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Место покупки:" FontSize="14"/>
            <ComboBox x:Name="CbLocation" DisplayMemberPath="Address" Margin="0,5,0,10" Padding="3"/>

            <TextBlock Text="Описание:" FontSize="14"/>
            <TextBox x:Name="TbDescription" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,10" Padding="3"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="SaveBtn" Content="СОХРАНИТЬ" Padding="15,10" Margin="0,0,10,0" Click="SaveBtn_Click"/>
                <Button x:Name="CancelBtn" Content="ОТМЕНА" Padding="15,10" Click="CancelBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>