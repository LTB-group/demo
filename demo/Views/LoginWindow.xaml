<Window x:Class="WpfApp4.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="400" Width="350"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">
            <TextBlock Text="Вход в систему" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Логин:" FontSize="14"/>
            <TextBox x:Name="LoginTb" Margin="0,5,0,15" Padding="5"/>
            <TextBlock Text="Пароль:" FontSize="14"/>
            <PasswordBox x:Name="PasswordTb" Margin="0,5,0,25" Padding="5"/>
            <Button x:Name="LoginBtn" Content="ВОЙТИ" Padding="10" Click="LoginBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>