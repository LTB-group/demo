<Window x:Class="WpfApp4.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp4.Views"
        Title="Каталог товаров" Height="650" Width="950" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:DiscountColorConverter x:Key="DiscountConverter"/>
        <local:ImagePathConverter x:Key="ImageConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderPanel" Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Images/ЛОГО.jpg" Height="60" Width="60" Stretch="Uniform" Grid.Column="0" Margin="10"/>
            <TextBlock Text="ООО «Техника для больницы»" FontSize="20" VerticalAlignment="Center" Margin="15,0,0,0" Grid.Column="1"/>
            <TextBlock x:Name="UserNameTb" FontSize="14" VerticalAlignment="Center" Margin="30,0,0,0" Grid.Column="2"/>
            <Button x:Name="LogoutBtn" Content="ВЫХОД" Margin="10" Padding="10,5" Click="LogoutBtn_Click" HorizontalAlignment="Right" Grid.Column="3"/>
        </Grid>

        <StackPanel x:Name="SearchPanel" Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <TextBox x:Name="SearchTb" Width="300" Padding="2" TextChanged="SearchTb_TextChanged"/>
        </StackPanel>

        <ListView x:Name="ProductsList" Grid.Row="2" Margin="10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="5" Padding="10" Width="850"
                            Background="{Binding DiscountAmount, Converter={StaticResource DiscountConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding PhotoPath, Converter={StaticResource ImageConverter}}" 
                                   Width="110" Height="110" Stretch="Uniform" Grid.Column="0"/>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5,0,5"/>
                                <TextBlock Text="{Binding Manufacturer.Name, StringFormat='Производитель: {0}'}"/>
                                <TextBlock Text="{Binding Category.Name, StringFormat='Категория: {0}'}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} руб.'}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DiscountAmount, StringFormat='Скидка: {0}%'}" Foreground="Red" FontSize="14" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel x:Name="AdminPanel" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="AddBtn" Content="ДОБАВИТЬ" Padding="15,10" Margin="5" Click="AddBtn_Click"/>
            <Button x:Name="EditBtn" Content="РЕДАКТИРОВАТЬ" Padding="15,10" Margin="5" Click="EditBtn_Click"/>
            <Button x:Name="DeleteBtn" Content="УДАЛИТЬ" Padding="15,10" Margin="5" Click="DeleteBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>